<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.conduit">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Conduit">
        <activity android:name=".activities.AddVacationActivity"
                android:exported="true"
            >
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <activity android:name=".activities.VacationActivity"
                android:exported="true"
            />
        <activity android:name=".activities.UpdateExcursionActivity"
                android:exported="true"
            />
        <activity android:name=".activities.ExcursionActivity"
                android:exported="true"
            />
    </application>

</manifest>